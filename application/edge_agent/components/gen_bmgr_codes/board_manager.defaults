# --- Board-specific configuration (managed by esp_board_manager) ---
# Board: esp32_S3_DevKitC_1
CONFIG_IDF_TARGET="esp32s3"
CONFIG_ESP_BOARD_ESP32_S3_DEVKITC_1=y
CONFIG_ESP_BOARD_NAME="esp32_S3_DevKitC_1"

CONFIG_ESP_BOARD_PERIPH_RMT_SUPPORT=y
CONFIG_ESP_BOARD_DEV_CUSTOM_SUPPORT=y
# --- End of board-specific configuration ---

# --- Board sdkconfig defaults ---
# Source: /home/ket/.openclaw/workspace/esp-claw/application/edge_agent/boards/espressif/esp32_S3_DevKitC_1/sdkconfig.defaults.board
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_APP_CLAW_LUA_MODULE_LCD=y
# --- End of Board sdkconfig defaults ---
