CONFIG_BT_NIMBLE_GATT_CLIENT=n
CONFIG_BT_ALARM_MAX_NUM=20
CONFIG_BT_NIMBLE_PRINT_ERR_NAME=n
CONFIG_BT_CTRL_BLE_MAX_ACT=2
CONFIG_BT_CTRL_ADV_DUP_FILT_MAX=1
